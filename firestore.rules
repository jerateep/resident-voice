rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. Boards Collection
    match /boards/{boardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Admins Collection
    match /admins/{uid} {
      // Users can only read their own admin record to verify status
      allow read: if request.auth != null && request.auth.uid == uid;
      // Writing admin status is restricted to Firebase Console only
      allow write: if false; 
    }

    // 3. Artifacts Subcollections (Cards and Groups)
    match /artifacts/{boardId}/public/data/groups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /artifacts/{boardId}/public/data/cards/{cardId} {
      allow read: if true;
      
      // Creating a new card requires authentication (anonymous or google)
      allow create: if request.auth != null;
      
      // Allowed updates for normal users: voting fields
      // Admins can fully update
      allow update: if isAdmin() || (
        request.auth != null &&
        // Normal users can ONLY modify these specific fields
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['votes', 'likedBy', 'likedNames', 'likedDevices'])
      );

      // Only admins or the original creator can delete
      allow delete: if isAdmin() || (request.auth != null && resource.data.creatorId == request.auth.uid);
    }

    // 4. Audit Logs (Admin only)
    match /artifacts/{boardId}/public/data/auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // 5. Polls Collection
    match /artifacts/{boardId}/public/data/polls/{pollId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['agree', 'disagree', 'abstain']);
      allow delete: if isAdmin() || (request.auth != null && resource.data.creatorId == request.auth.uid);
    }

  }
}
